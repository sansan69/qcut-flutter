rules_version = '2';
service cloud.firestore {
  // Authenticated users (admin / provider / customer) can read/write their own
  // data. App Check (`request.app != null`) is only required for public /
  // anonymous access — e.g. the web booking page or onboarding submissions.
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isAuthenticated() && request.auth.token.role == 'platform_admin';
    }

    function isProviderForTenant(tenantId) {
      return isAuthenticated()
        && request.auth.token.role == 'provider'
        && request.auth.token.tenantId == tenantId;
    }

    // ── Tenants ──
    match /tenants/{tenantId} {
      allow read: if isPlatformAdmin() || isProviderForTenant(tenantId) || resource.data.status == 'active';
      allow create: if isAuthenticated();  // owner auto-create or admin create
      allow update: if isPlatformAdmin() || isProviderForTenant(tenantId);
      allow delete: if isPlatformAdmin();
    }

    // ── Staff / Barbers (public read if active) ──
    match /tenants/{tenantId}/staff/{id} {
      allow read: if isPlatformAdmin() || isProviderForTenant(tenantId) || resource.data.isActive == true;
      allow create, update, delete: if isPlatformAdmin() || isProviderForTenant(tenantId);
    }

    match /tenants/{tenantId}/barbers/{id} {
      allow read: if isPlatformAdmin() || isProviderForTenant(tenantId) || resource.data.isActive == true;
      allow create, update, delete: if isPlatformAdmin() || isProviderForTenant(tenantId);
    }

    // ── Services (public read if active) ──
    match /tenants/{tenantId}/services/{id} {
      allow read: if isPlatformAdmin() || isProviderForTenant(tenantId) || resource.data.isActive == true;
      allow create, update, delete: if isPlatformAdmin() || isProviderForTenant(tenantId);
    }

    // ── Slots ──
    match /tenants/{tenantId}/slots/{id} {
      allow read: if true;
      allow create, update: if isPlatformAdmin() || isProviderForTenant(tenantId);
      allow delete: if isPlatformAdmin();
    }

    // ── Bookings (customers create, admin/provider manage) ──
    match /tenants/{tenantId}/bookings/{id} {
      allow read: if isPlatformAdmin()
        || isProviderForTenant(tenantId)
        || (isAuthenticated() && request.auth.uid == resource.data.customerId);
      allow create: if isAuthenticated();
      allow update: if isPlatformAdmin() || isProviderForTenant(tenantId);
      allow delete: if isPlatformAdmin();
    }

    // ── Customers ──
    match /tenants/{tenantId}/customers/{id} {
      allow read, create, update: if isPlatformAdmin() || isProviderForTenant(tenantId);
      allow delete: if isPlatformAdmin();
    }

    // ── Token queue entries (customers create, admin/provider manage) ──
    match /tenants/{tenantId}/tokens/{date}/entries/{entryId} {
      allow read: if isPlatformAdmin()
        || isProviderForTenant(tenantId)
        || (isAuthenticated() && request.auth.uid == resource.data.customerId);
      allow create: if isAuthenticated();
      allow update: if isPlatformAdmin() || isProviderForTenant(tenantId);
      allow delete: if isPlatformAdmin();
    }

    // ── Users (own data only) ──
    match /users/{uid} {
      allow read, update: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if isPlatformAdmin();
    }

    // ── Onboarding submissions (public create, admin review) ──
    match /onboarding_submissions/{id} {
      allow create: if true;  // anyone can submit onboarding
      allow read, update, delete: if isPlatformAdmin();
    }

    // ── Plans (public read, admin write) ──
    match /plans/{id} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // ── Audit logs ──
    match /audit_logs/{id} {
      allow read: if isPlatformAdmin();
      allow create: if isAuthenticated();
    }
  }
}
