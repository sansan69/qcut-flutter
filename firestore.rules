rules_version = '2';
service cloud.firestore {
  // App Check enforcement is ENABLED for writes and authenticated reads below
  // (`&& request.app != null`). Public reads needed for the anonymous web booking
  // page are exempt; add reCAPTCHA v3 App Check later and tighten these if desired.
  // Rollout recommendation: turn on App Check in monitor-only mode in the Firebase
  // console first to collect metrics and verify legitimate clients pass attestation,
  // then keep these rule clauses once the false-positive rate is acceptable.
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isAuthenticated() && request.auth.token.role == 'platform_admin';
    }

    function isProviderForTenant(tenantId) {
      return isAuthenticated()
        && request.auth.token.role == 'provider'
        && request.auth.token.tenantId == tenantId;
    }

    function isCustomer() {
      return isAuthenticated() && request.auth.token.role == 'customer';
    }

    // Public read for active tenants enables the web booking page (qcut.co.in/s/{slug}).
    // App Check is required for writes and authenticated reads; public reads are open so
    // anonymous customers can view the shop without an attestation token.
    match /tenants/{tenantId} {
      allow read: if isPlatformAdmin() || isProviderForTenant(tenantId) || resource.data.status == 'active';
      allow create: if isPlatformAdmin() && request.app != null;
      allow update: if (isPlatformAdmin() || isProviderForTenant(tenantId)) && request.app != null;
      allow delete: if isPlatformAdmin() && request.app != null;
    }

    // Public read for staff and services lets customers see availability on the booking page.
    match /tenants/{tenantId}/staff/{id} {
      allow read: if isPlatformAdmin() || isProviderForTenant(tenantId) || resource.data.status == 'active';
    }

    match /tenants/{tenantId}/services/{id} {
      allow read: if isPlatformAdmin() || isProviderForTenant(tenantId) || resource.data.status == 'active';
    }

    match /tenants/{tenantId}/bookings/{id} {
      allow read: if (isPlatformAdmin() || isProviderForTenant(tenantId)) && request.app != null;
    }

    match /tenants/{tenantId}/customers/{id} {
      allow read: if (isPlatformAdmin() || isProviderForTenant(tenantId)) && request.app != null;
    }

    match /tenants/{tenantId}/tokens/{date}/entries/{entryId} {
      allow read: if (isPlatformAdmin() || isProviderForTenant(tenantId) || isCustomer()) && request.app != null;
      allow create, update: if (isPlatformAdmin() || isProviderForTenant(tenantId)) && request.app != null;
      allow delete: if isPlatformAdmin() && request.app != null;
    }

    match /users/{uid} {
      allow read, update: if isAuthenticated() && request.auth.uid == uid && request.app != null;
      allow create: if isAuthenticated() && request.auth.uid == uid && request.app != null;
      allow delete: if isPlatformAdmin() && request.app != null;
    }

    match /onboarding_submissions/{id} {
      allow create: if true && request.app != null;
      allow read, update, delete: if isPlatformAdmin() && request.app != null;
    }

    match /plans/{id} {
      allow read: if true && request.app != null;
      allow write: if isPlatformAdmin() && request.app != null;
    }

    match /audit_logs/{id} {
      allow read: if isPlatformAdmin() && request.app != null;
      allow create: if isAuthenticated() && request.app != null;
    }
  }
}
